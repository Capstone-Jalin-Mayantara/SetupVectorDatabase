# API Keys
GOOGLE_API_KEY=your_google_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# 1. Main Database (PostgreSQL - RDS) - Task 1.2
DB_HOST=your_rds_endpoint_here
DB_NAME=asiq_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_PORT=5432

# 2. Cache Memory (Redis - ElastiCache) - Task 1.4
REDIS_HOST=your_elasticache_endpoint_here
REDIS_PORT=6379

# 3. Vector Database (ChromaDB) - Task 1.3
CHROMA_PERSIST_DIRECTORY=./chroma_db
