# ── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Main Database (PostgreSQL - Amazon RDS) ───────────────────────────────────
DB_HOST=your_rds_endpoint_here
DB_NAME=asiq_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_PORT=5432

# ── Cache (Redis - Amazon ElastiCache) ───────────────────────────────────────
REDIS_HOST=your_elasticache_endpoint_here
REDIS_PORT=6379

# ── Storage (Amazon S3) ───────────────────────────────────────────────────────
S3_BUCKET=your_s3_bucket_name_here
AWS_REGION=ap-southeast-1

# ── PostgreSQL Connection Pool ────────────────────────────────────────────────
DB_POOL_MIN=1
DB_POOL_MAX=5
DB_CONNECT_TIMEOUT=5

# ── REST API ──────────────────────────────────────────────────────────────────
# API key untuk autentikasi semua endpoint (header: X-API-Key)
API_KEY=your_secret_api_key_here

# Asal domain frontend yang diizinkan (CORS), pisahkan dengan koma
# Contoh production: https://asiq.yourdomain.com
# Contoh development: http://localhost:3000
ALLOWED_ORIGINS=*

# Durasi job tersimpan di Redis dalam detik (default: 86400 = 24 jam)
JOB_TTL_SECONDS=86400

# ── Batch Processing ──────────────────────────────────────────────────────────
# Max pipeline AI yang berjalan bersamaan (jangan > 2 agar tidak throttle Groq)
BATCH_MAX_WORKERS=2
# Max siswa per satu request batch
BATCH_MAX_STUDENTS=10

# ── Groq Rate Limiting ────────────────────────────────────────────────────────
# Delay antar task dalam satu pipeline (detik). Turunkan jika pakai Groq paid tier.
# Default 30 (was 60). Set 0 untuk nonaktifkan (paid tier / model lain).
GROQ_TASK_DELAY=30
# Delay antar step dalam satu task (detik). Default 8 (was 30).
GROQ_STEP_DELAY=8
# Jumlah retry otomatis jika kena rate limit 429
GROQ_MAX_RETRIES=3
